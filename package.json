{
	"name": "focused-todo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "mkdir -p logs && vite dev --port 7010 2>&1 | tee logs/dev.log",
		"test:dev": "vite dev --port 7002",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "yarn test:unit -- --run",
		"db:reset": "node scripts/db-reset.js",
		"db:seed": "node scripts/db-seed.js",
		"db:rebuild": "node scripts/db-reset.js && node scripts/db-seed.js",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"electron-rebuild": "^3.2.9",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"better-sqlite3": "^12.9.0"
	}
}
